# Copy this to Railway as environment variables
# DO NOT commit this file with real values to GitHub

# From BotFather on Telegram
TELEGRAM_TOKEN=your_bot_token_here

# Your Telegram chat ID (get from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# How often to poll feeds in seconds (180 = 3 minutes)
POLL_INTERVAL=180
